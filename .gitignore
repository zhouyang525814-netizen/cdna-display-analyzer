node_modules
dist
.turbo
.vite
.vitest-cache
*.log
.DS_Store

# Rust build cache only — the wasm-pack outputs in pkg/ and pkg-web/ are
# checked in so deploy environments (Vercel, etc.) don't need a Rust
# toolchain. Re-run `pnpm --filter @cdna/core-wasm build:wasm` after
# editing src/lib.rs to refresh them.
packages/core-wasm/target

# Environment files — never commit OAuth keys / API tokens.
.env
.env.local
.env.*.local

# IDE.
.vscode
.idea
*.swp

# Stray tsc emissions if tsconfig ever picks up test files
packages/*/test/**/*.js
packages/*/test/**/*.d.ts
packages/*/test/**/*.map
